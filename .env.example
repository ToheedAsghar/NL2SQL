# ── OpenAI Provider ──────────────────────────────
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Gemini Provider ──────────────────────────────
GEMINI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxx
GEMINI_BASE_URL=https://openrouter.ai/api/v1
GEMINI_MODEL=google/gemini-2.5-flash

# ── Database ─────────────────────────────────────
DB_TYPE=sqlite
DB_PATH=./spider/database/concert_singer/concert_singer.sqlite

# ── Pipeline Tuning ─────────────────────────────
MAX_TOKENS=4096
CACHE_TTL_HOURS=24
N_CANDIDATES=3
MAX_RETRIES=2
DISCOVERY_TOP_K=5
KEYWORD_PRE_FILTER_TOP_N=50
